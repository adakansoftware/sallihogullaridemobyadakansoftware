# Admin login credentials used for the protected admin panel.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-this-password-to-12-plus-chars"

# Optional: instead of ADMIN_PASSWORD, you can provide a pre-hashed scrypt password.
# Format: scrypt:<salt-base64url>:<hash-base64url>
# ADMIN_PASSWORD_HASH=""

# Use a long random value for secure session signing.
ADMIN_SESSION_SECRET="change-this-session-secret-to-32-plus-chars"

# Both origins should match the live production domain.
APP_ORIGIN="https://example.com"
NEXT_PUBLIC_SITE_URL="https://example.com"

# Add the value Google Search Console gives for the HTML meta verification tag.
# Example: <meta name="google-site-verification" content="abc123" />
GOOGLE_SITE_VERIFICATION=""
